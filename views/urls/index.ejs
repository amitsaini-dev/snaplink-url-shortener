<% layout("/layouts/boilerplate.ejs") %>

<div class="row justify-content-center">
  <div class="col-md-7">
    <div class="card shadow-sm border-0 mt-4">
      <div class="card-body p-4">

        <h4 class="mb-4 fw-semibold">🔗 Shorten a URL</h4>

        <form method="POST" action="/urls">

          <!-- ── Long URL ───────────────────────────── -->
          <div class="mb-3">
            <label for="originalUrl" class="form-label fw-medium">Long URL</label>
            <input
              type="text"
              id="originalUrl"
              name="url[originalUrl]"
              class="form-control"
              placeholder="https://example.com/very/long/link"
              required
            >
          </div>

          <!-- ── Short Alias Field ─────────────────── -->
          <div class="mb-3">
            <label for="shortCode" class="form-label fw-medium">Short alias</label>

            <input
              type="text"
              id="shortCode"
              name="url[shortCode]"
              class="form-control mb-2"
              placeholder="Click a button below, or type your own"
            >

            <!-- Hidden: tracks how alias was made -->
            <input type="hidden" id="aliasType" name="url[aliasType]" value="custom">

            <!-- ── Three Buttons ───────────────────── -->
            <div class="d-flex gap-2 flex-wrap align-items-center">

              <button type="button" id="btn-generate" class="btn btn-outline-secondary btn-sm">
                ⚡ Generate random
              </button>

              <button type="button" id="btn-ai" class="btn btn-outline-primary btn-sm">
                🤖 AI alias
              </button>

              <span class="text-muted small">or type your own above</span>

            </div>

            <!-- Feedback message shows here -->
            <div id="alias-feedback" class="mt-2 small"></div>
          </div>

          <!-- ── Submit ────────────────────────────── -->
          <button type="submit" class="btn btn-dark w-100 mt-1">
            ✅ Save short URL
          </button>

        </form>

      </div>
    </div>
  </div>
</div>
